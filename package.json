{
  "name": "token-vocabs",
  "version": "0.2.2",
  "type": "module",
  "description": "Count and inspect token IDs across several modern tokenizer families offline.",
  "keywords": [
    "bpe",
    "count-tokens",
    "deepseek",
    "gemma",
    "gpt",
    "kimi",
    "llm",
    "minimax",
    "qwen",
    "sdxl",
    "tokenizer"
  ],
  "funding": "https://github.com/sponsors/Jaid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jaid/token-vocabs.git"
  },
  "exports": {
    ".": {
      "types": "./src/main.ts",
      "import": "./src/main.ts",
      "default": "./src/main.ts"
    },
    "./browser": {
      "types": "./src/browser/main.ts",
      "import": "./src/browser/main.ts",
      "default": "./src/browser/main.ts"
    },
    "./browser/all": {
      "types": "./src/browser/all.ts",
      "import": "./src/browser/all.ts",
      "default": "./src/browser/all.ts"
    }
  },
  "imports": {
    "#tiktoken": {
      "browser": "./src/browser/tiktoken.ts",
      "default": "./src/lib/tiktoken.ts"
    },
    "#src/*": "./src/*",
    "#root/*": "./*"
  },
  "scripts": {
    "build": "bun run ensure-data && bun scripts/build.ts",
    "ensure-data": "bun scripts/ensureData.ts",
    "fetch": "bun scripts/fetch.ts",
    "lint": "bun run ensure-data && bun x eslint .",
    "test": "bun run ensure-data && bun test"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "brotli": "^1.3.3",
    "msgpackr": "^2.0.2",
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "cbor-x": "^1.6.4",
    "eslint": "^10.4.0",
    "eslint-config-jaid": "^26.0.0",
    "fs-extra": "^11.3.5",
    "rolldown": "^1.0.3",
    "rolldown-plugin-wasm": "^0.2.1",
    "serialize-javascript": "^7.0.5",
    "tsconfig-jaid-bun": "^15.2.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "src",
    "temp/generated",
    "license.txt",
    "readme.md"
  ]
}